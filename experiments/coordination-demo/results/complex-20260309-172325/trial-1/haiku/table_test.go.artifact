package display

import (
	"strings"
	"testing"
)

func TestRenderTable_BasicTable(t *testing.T) {
	headers := []string{"Name", "Status"}
	rows := [][]string{
		{"Alice", "active"},
		{"Bob", "inactive"},
	}

	result := RenderTable(headers, rows)

	// Check that result contains headers
	if !strings.Contains(result, "Name") || !strings.Contains(result, "Status") {
		t.Errorf("RenderTable: headers not found in output:\n%s", result)
	}

	// Check that result contains rows
	if !strings.Contains(result, "Alice") || !strings.Contains(result, "Bob") {
		t.Errorf("RenderTable: rows not found in output:\n%s", result)
	}

	// Check that separator exists (should be dashes)
	if !strings.Contains(result, "---") {
		t.Errorf("RenderTable: separator not found in output:\n%s", result)
	}
}

func TestRenderTable_EmptyRows(t *testing.T) {
	headers := []string{"Col1", "Col2", "Col3"}
	rows := [][]string{}

	result := RenderTable(headers, rows)

	// Should still render headers and separator
	if !strings.Contains(result, "Col1") {
		t.Errorf("RenderTable with empty rows: headers not found in output:\n%s", result)
	}
	if !strings.Contains(result, "---") {
		t.Errorf("RenderTable with empty rows: separator not found in output:\n%s", result)
	}
}

func TestRenderTable_ANSIColoredContent(t *testing.T) {
	headers := []string{"Name", "Status"}
	rows := [][]string{
		{"\x1b[31mAlice\x1b[0m", "\x1b[32mactive\x1b[0m"},
		{"\x1b[31mBob\x1b[0m", "\x1b[31minactive\x1b[0m"},
	}

	result := RenderTable(headers, rows)

	// Check that result contains the colored text (with ANSI codes)
	if !strings.Contains(result, "\x1b[31mAlice\x1b[0m") {
		t.Errorf("RenderTable: ANSI-colored content not preserved:\n%s", result)
	}

	// Verify alignment by checking visual widths
	// The separator should be 4 characters wide for "Name" and 6 for "Status"
	// even though the actual strings are longer due to ANSI codes
	lines := strings.Split(result, "\n")
	if len(lines) < 3 {
		t.Fatalf("RenderTable: expected at least 3 lines (header, separator, row), got %d", len(lines))
	}

	// The separator line shows the actual column widths
	separatorLine := lines[1]
	// Should have two sets of dashes separated by two spaces
	if !strings.Contains(separatorLine, "----") {
		t.Errorf("RenderTable: separator line malformed:\n%s", separatorLine)
	}
}

func TestRenderTable_MismatchedColumnCounts(t *testing.T) {
	headers := []string{"A", "B", "C"}
	rows := [][]string{
		{"a1", "b1"},        // fewer columns than headers
		{"a2", "b2", "c2"},  // same columns as headers
		{"a3", "b3", "c3", "d3"}, // more columns than headers
	}

	result := RenderTable(headers, rows)

	// Should not panic and should contain all headers
	if !strings.Contains(result, "A") || !strings.Contains(result, "B") || !strings.Contains(result, "C") {
		t.Errorf("RenderTable: headers not found with mismatched rows:\n%s", result)
	}

	// Should contain all row data
	if !strings.Contains(result, "a1") || !strings.Contains(result, "d3") {
		t.Errorf("RenderTable: row data not found with mismatched columns:\n%s", result)
	}
}

func TestRenderTable_SingleColumn(t *testing.T) {
	headers := []string{"Items"}
	rows := [][]string{
		{"apple"},
		{"banana"},
		{"cherry"},
	}

	result := RenderTable(headers, rows)

	if !strings.Contains(result, "Items") {
		t.Errorf("RenderTable single column: header not found:\n%s", result)
	}

	if !strings.Contains(result, "apple") || !strings.Contains(result, "banana") {
		t.Errorf("RenderTable single column: rows not found:\n%s", result)
	}
}

func TestRenderTable_ColumnAlignment(t *testing.T) {
	headers := []string{"Short", "VeryLongHeader"}
	rows := [][]string{
		{"x", "y"},
		{"ab", "cd"},
		{"abc", "defghij"},
	}

	result := RenderTable(headers, rows)
	lines := strings.Split(result, "\n")

	// All non-empty lines should have similar structure
	for i, line := range lines {
		if i > 0 && line != "" {
			// Each line should have the two-space separator
			parts := strings.Split(line, "  ")
			if len(parts) < 2 {
				t.Errorf("RenderTable: line %d missing separator:\n%s", i, line)
			}
		}
	}
}

func TestRenderTable_EmptyHeaders(t *testing.T) {
	headers := []string{}
	rows := [][]string{
		{"a", "b"},
	}

	result := RenderTable(headers, rows)

	// Should return empty string for empty headers
	if result != "" {
		t.Errorf("RenderTable with empty headers: expected empty string, got:\n%s", result)
	}
}

func TestRenderTable_ComplexANSIPatterns(t *testing.T) {
	headers := []string{"Red", "Green", "Bold"}
	rows := [][]string{
		{
			"\x1b[31m\x1b[1mBoldRed\x1b[0m",
			"\x1b[32mGreen\x1b[0m",
			"\x1b[1mBold\x1b[0m",
		},
		{
			"Plain",
			"\x1b[1;32mBoldGreen\x1b[0m",
			"\x1b[1;33m\x1b[4mBoldYellowUnderline\x1b[0m",
		},
	}

	result := RenderTable(headers, rows)

	// Verify all ANSI-colored cells are preserved
	if !strings.Contains(result, "\x1b[31m") || !strings.Contains(result, "\x1b[32m") {
		t.Errorf("RenderTable: ANSI codes not preserved:\n%s", result)
	}

	// Verify plain text cells are still present
	if !strings.Contains(result, "Plain") {
		t.Errorf("RenderTable: plain text row not found:\n%s", result)
	}
}

func TestRenderTable_LineCount(t *testing.T) {
	headers := []string{"A", "B"}
	rows := [][]string{
		{"a1", "b1"},
		{"a2", "b2"},
		{"a3", "b3"},
	}

	result := RenderTable(headers, rows)
	lines := strings.Split(result, "\n")

	// Should have: header + separator + 3 data rows = 5 lines
	expectedLines := 5
	if len(lines) != expectedLines {
		t.Errorf("RenderTable: expected %d lines, got %d:\n%s", expectedLines, len(lines), result)
	}
}

func TestRenderTable_ColumnPadding(t *testing.T) {
	headers := []string{"A", "B"}
	rows := [][]string{
		{"short", "x"},
		{"verylongtext", "y"},
	}

	result := RenderTable(headers, rows)
	lines := strings.Split(result, "\n")

	// All lines (except empty ones) should have proper spacing
	for i, line := range lines {
		if line == "" {
			continue
		}
		// Count characters up to first two-space separator
		// This verifies padding is working
		if !strings.Contains(line, "  ") {
			t.Logf("Line %d: %s", i, line)
		}
	}
}
