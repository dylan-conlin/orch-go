package display

import (
	"strings"
	"testing"
)

func TestRenderTable_Basic(t *testing.T) {
	headers := []string{"Name", "Status", "Age"}
	rows := [][]string{
		{"Alice", "Active", "30"},
		{"Bob", "Inactive", "25"},
	}

	got := RenderTable(headers, rows)

	// Check that all content is present
	if !strings.Contains(got, "Name") || !strings.Contains(got, "Status") || !strings.Contains(got, "Age") {
		t.Errorf("Missing headers in output:\n%s", got)
	}
	if !strings.Contains(got, "Alice") || !strings.Contains(got, "Bob") {
		t.Errorf("Missing row data in output:\n%s", got)
	}
	// Check separator line exists
	if !strings.Contains(got, "---") {
		t.Errorf("Missing separator line in output:\n%s", got)
	}
}

func TestRenderTable_EmptyRows(t *testing.T) {
	headers := []string{"Col1", "Col2"}
	rows := [][]string{}

	got := RenderTable(headers, rows)

	// Should have headers and separator, but no data rows
	lines := strings.Split(strings.TrimSpace(got), "\n")
	if len(lines) != 2 {
		t.Errorf("Expected 2 lines (header + separator), got %d:\n%s", len(lines), got)
	}
	if !strings.Contains(lines[0], "Col1") || !strings.Contains(lines[0], "Col2") {
		t.Errorf("Headers not found in first line:\n%s", got)
	}
}

func TestRenderTable_ANSIAlignment(t *testing.T) {
	red := "\x1b[31m"
	green := "\x1b[32m"
	reset := "\x1b[0m"

	headers := []string{"Status", "Name"}
	rows := [][]string{
		{red + "Error" + reset, "Task A"},
		{green + "OK" + reset, "Task B"},
	}

	got := RenderTable(headers, rows)

	// The "Status" column should be wide enough for "Error" (5 chars)
	// even though the ANSI codes make the string longer in bytes
	lines := strings.Split(strings.TrimSpace(got), "\n")
	if len(lines) < 3 {
		t.Fatalf("Expected at least 3 lines, got %d:\n%s", len(lines), got)
	}

	// Check that "Task A" and "Task B" align vertically
	// Find position of "Task A" in line 3 and "Task B" in line 4
	taskAPos := strings.Index(lines[2], "Task A")
	taskBPos := strings.Index(lines[3], "Task B")
	if taskAPos != taskBPos {
		t.Errorf("ANSI alignment failed: Task A at pos %d, Task B at pos %d\n%s", taskAPos, taskBPos, got)
	}
}

func TestRenderTable_FewerColumnsThanHeaders(t *testing.T) {
	headers := []string{"A", "B", "C"}
	rows := [][]string{
		{"1", "2", "3"},
		{"4", "5"}, // Missing column C
		{"6"},      // Missing columns B and C
	}

	got := RenderTable(headers, rows)

	// Should not panic, should render with empty cells
	lines := strings.Split(strings.TrimSpace(got), "\n")
	if len(lines) != 5 { // header + separator + 3 data rows
		t.Errorf("Expected 5 lines, got %d:\n%s", len(lines), got)
	}
}

func TestRenderTable_MoreColumnsThanHeaders(t *testing.T) {
	headers := []string{"A", "B"}
	rows := [][]string{
		{"1", "2", "extra", "ignored"}, // Extra columns
		{"3", "4"},
	}

	got := RenderTable(headers, rows)

	// Extra columns should be ignored
	if strings.Contains(got, "extra") || strings.Contains(got, "ignored") {
		t.Errorf("Extra columns should be ignored:\n%s", got)
	}
}

func TestRenderTable_SingleColumn(t *testing.T) {
	headers := []string{"Items"}
	rows := [][]string{
		{"Apple"},
		{"Banana"},
		{"Cherry"},
	}

	got := RenderTable(headers, rows)

	if !strings.Contains(got, "Items") {
		t.Errorf("Missing header:\n%s", got)
	}
	if !strings.Contains(got, "Apple") || !strings.Contains(got, "Banana") || !strings.Contains(got, "Cherry") {
		t.Errorf("Missing row data:\n%s", got)
	}
	// Single column should not have column separators
	if strings.Contains(got, "|") {
		t.Errorf("Single column should not have | separators:\n%s", got)
	}
}

func TestRenderTable_EmptyHeaders(t *testing.T) {
	headers := []string{}
	rows := [][]string{{"data"}}

	got := RenderTable(headers, rows)

	if got != "" {
		t.Errorf("Expected empty string for empty headers, got:\n%s", got)
	}
}

func TestRenderTable_ColumnWidthAutoSize(t *testing.T) {
	headers := []string{"ID", "Description"}
	rows := [][]string{
		{"1", "Short"},
		{"2", "A much longer description here"},
	}

	got := RenderTable(headers, rows)

	// The separator line under "Description" should be at least as wide
	// as "A much longer description here" (30 chars)
	lines := strings.Split(strings.TrimSpace(got), "\n")
	if len(lines) < 2 {
		t.Fatalf("Expected at least 2 lines, got %d", len(lines))
	}
	separatorLine := lines[1]
	// Count dashes in the second column section
	parts := strings.Split(separatorLine, "-+-")
	if len(parts) < 2 {
		t.Fatalf("Expected separator with -+-, got: %s", separatorLine)
	}
	descColWidth := len(parts[1])
	if descColWidth < 30 {
		t.Errorf("Description column width %d should be at least 30:\n%s", descColWidth, got)
	}
}
