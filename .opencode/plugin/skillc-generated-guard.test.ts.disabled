import { describe, expect, test } from "bun:test"
import { mkdtemp, rm, writeFile } from "node:fs/promises"
import { tmpdir } from "node:os"
import { join } from "node:path"

import { SkillcGeneratedGuardPlugin } from "./skillc-generated-guard"

async function withTempDir(run: (dir: string) => Promise<void>) {
  const dir = await mkdtemp(join(tmpdir(), "skillc-guard-"))
  try {
    await run(dir)
  } finally {
    await rm(dir, { recursive: true, force: true })
  }
}

async function createBeforeHook(directory: string) {
  const hooks = await SkillcGeneratedGuardPlugin({
    directory,
    worktree: directory,
    client: {} as any,
    project: {} as any,
    $: {} as any,
    serverUrl: new URL("https://localhost"),
  })

  const beforeHook = hooks["tool.execute.before"]
  if (!beforeHook) {
    throw new Error("tool.execute.before hook not defined")
  }
  return beforeHook
}

describe("SkillcGeneratedGuardPlugin", () => {
  test("blocks edit when marker is in first 5 lines", async () => {
    await withTempDir(async (directory) => {
      const filePath = join(directory, "SKILL.md")
      await writeFile(
        filePath,
        [
          "<!-- AUTO-GENERATED by skillc -->",
          "<!-- Source: /tmp/example/.skillc -->",
          "# Skill",
          "",
        ].join("\n"),
      )

      const beforeHook = await createBeforeHook(directory)

      await expect(
        beforeHook(
          { tool: "edit", sessionID: "ses_1", callID: "call_1" },
          { args: { filePath } },
        ),
      ).rejects.toThrow("Edit the .skillc source instead")
    })
  })

  test("does not block when marker appears after first 5 lines", async () => {
    await withTempDir(async (directory) => {
      const filePath = join(directory, "SKILL.md")
      await writeFile(
        filePath,
        [
          "line 1",
          "line 2",
          "line 3",
          "line 4",
          "line 5",
          "<!-- AUTO-GENERATED by skillc -->",
        ].join("\n"),
      )

      const beforeHook = await createBeforeHook(directory)

      await expect(
        beforeHook(
          { tool: "edit", sessionID: "ses_1", callID: "call_1" },
          { args: { filePath } },
        ),
      ).resolves.toBeUndefined()
    })
  })

  test("does not block writes for files that do not exist yet", async () => {
    await withTempDir(async (directory) => {
      const filePath = join(directory, "new-file.md")
      const beforeHook = await createBeforeHook(directory)

      await expect(
        beforeHook(
          { tool: "write", sessionID: "ses_1", callID: "call_1" },
          { args: { filePath } },
        ),
      ).resolves.toBeUndefined()
    })
  })
})
