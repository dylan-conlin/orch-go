# Binary
orch-go
build/

# Test/dev executables at root
/orch
/orch-new
/orch-test
/orch-test-*
/test-*

# Build artifacts in cmd/
cmd/orch/orch

# Backup files
*.bak
*.bak2

# Private keys / certificates (never track)
pkg/certs/

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Web UI (SvelteKit)
web/node_modules/
web/.svelte-kit/
web/build/
tmp/

# Agent workspace artifacts (ephemeral, per-session)
.orch/workspace/

# Dev/Ops mode (local state, not committed)
.dev-mode

# Local build/config state
.autorebuild.lock
opencode.json

# Playwright CLI runtime artifacts
.playwright-cli/

# Harness subdirectory .claude dirs (harness init creates these but they
# cause Claude Code to treat subdirectories as project roots, breaking
# hook cwd resolution)
.harness/**/.claude/

# Literal tilde directory (safety — Go tools don't expand ~, creating ./~/*)
~
